    "test_url": "http://cp.cloudflare.com/generate_204",
    "expected_status": [204, 200],
    "timeout": 5,
    "batch_size": 100,
    "parallel_batches": 4,
    "base_port": 20000,
    "max_ping": 3000,
    "max_configs_to_test": 0,
    "max_output": 300,
    "min_per_country": 0
  }
}
