    "https://raw.githubusercontent.com/MatinGhanbari/v2ray-configs/main/subscriptions/v2ray/all_sub.txt"
  ],

  "github_token": "",
  "gist_id": "",
  "gist_filename": "zone-vpn.json",
  "gist_base64": true,

  "name_prefix": "zone-vpn",

  "interval_minutes": 10,

  "xray_path": "auto",
  "geoip_db": "GeoLite2-Country.mmdb",

  "test": {
